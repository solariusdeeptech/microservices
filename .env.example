# ============================================
# Solarius Microservices — Environment Variables
# ============================================

# --- API Gateway ---
GATEWAY_PORT=8080
LOG_LEVEL=INFO
REQUEST_TIMEOUT=300

# --- Backend Service URLs (for Gateway) ---
PYTHON_GEOSTAT_URL=http://python-geostat:8080
PYTHON_VIZ_URL=http://python-viz:8080

# --- Cloud Batch (heavy jobs) ---
GCP_PROJECT_ID=microservices-497617
GCP_REGION=europe-west1
GCS_BUCKET=solarius-jobs
JULIA_IMAGE=europe-west1-docker.pkg.dev/microservices-497617/solarius/julia-geostat:latest
PYTHON_HEAVY_IMAGE=europe-west1-docker.pkg.dev/microservices-497617/solarius/python-geostat:latest

# --- Routing Thresholds ---
MAX_POINTS_CLOUD_RUN=50000
MAX_BLOCKS_CLOUD_RUN=100000
MAX_REALIZATIONS_CLOUD_RUN=50

# --- API Keys (multi-tenant) ---
API_KEY_GEOECONOMIX=sk-solarius-change-me
API_KEY_GEOMATRIX=sk-geomatrix-change-me
API_KEY_TERRAEXPLORATION=sk-terra-change-me
