# ============================================
# Solarius Microservices — Environment Variables
# ============================================

# --- Julia Geostat Service ---
JULIA_PORT=8080
JULIA_WORKERS=4
JULIA_MAX_MEMORY_GB=8

# --- Python Viz Service ---
PYTHON_PORT=8081
PYVISTA_OFFSCREEN=true
MPS_MAX_GRID_SIZE=1000000

# --- API Gateway ---
GATEWAY_PORT=80

# --- API Keys (multi-tenant) ---
API_KEY_GEOECONOMIX=geoeconomix-prod-change-me
API_KEY_GEOMATRIX=geomatrix-prod-change-me
API_KEY_TERRAEXPLORATION=terra-prod-change-me

# --- GCP (production) ---
GCP_PROJECT_ID=solarius-microservices
GCP_REGION=europe-west1
ARTIFACT_REGISTRY=europe-west1-docker.pkg.dev/solarius-microservices/solarius
